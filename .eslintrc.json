{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-unused-vars": ["error", { "vars": "all", "args": "after-used", "argsIgnorePattern": "^next$" }]
  },
  "overrides": [
    {
      "files": ["**/*.test.js", "**/tests/**/*.js"],
      "env": {
        "jest": true
      }
    }
  ]
}
