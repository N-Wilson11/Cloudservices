{
  "openapi": "3.0.3",
  "info": {
    "title": "Photo Prestige API Gateway",
    "version": "1.2.0",
    "description": "Complete gateway documentation for all available API endpoints.\\n\\nRole model: participant, target-owner.\\n\\nEach operation includes role access in the description and x-allowed-roles."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local gateway"
    }
  ],
  "tags": [
    {
      "name": "Gateway"
    },
    {
      "name": "Auth"
    },
    {
      "name": "Targets"
    },
    {
      "name": "Register"
    },
    {
      "name": "Score"
    },
    {
      "name": "Read"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Health": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "version": {
            "type": "string",
            "example": "v1"
          },
          "service": {
            "type": "string",
            "example": "api-gateway"
          }
        }
      },
      "AuthPayload": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 6
          },
          "role": {
            "type": "string",
            "enum": [
              "participant",
              "target-owner"
            ],
            "description": "Required on register, ignored on login."
          }
        }
      },
      "TargetCreate": {
        "type": "object",
        "required": [
          "title",
          "imageUrl",
          "lat",
          "lng",
          "deadlineAt"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string",
            "format": "uri"
          },
          "locationDescription": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          },
          "radiusMeters": {
            "type": "number",
            "example": 250
          },
          "deadlineAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DeadlinePatch": {
        "type": "object",
        "required": [
          "deadlineAt"
        ],
        "properties": {
          "deadlineAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SubmissionCreate": {
        "type": "object",
        "required": [
          "imageUrl"
        ],
        "properties": {
          "imageUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "VotePayload": {
        "type": "object",
        "required": [
          "vote"
        ],
        "properties": {
          "vote": {
            "type": "string",
            "enum": [
              "up",
              "down"
            ]
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "Gateway"
        ],
        "summary": "Gateway health check",
        "description": "Allowed roles: public.",
        "x-allowed-roles": [
          "public"
        ],
        "responses": {
          "200": {
            "description": "Gateway is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/health": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Auth service health",
        "description": "Allowed roles: public.",
        "x-allowed-roles": [
          "public"
        ],
        "responses": {
          "200": {
            "description": "Auth service is healthy"
          }
        }
      }
    },
    "/api/v1/register/health": {
      "get": {
        "tags": [
          "Register"
        ],
        "summary": "Register service health",
        "description": "Allowed roles: public.",
        "x-allowed-roles": [
          "public"
        ],
        "responses": {
          "200": {
            "description": "Register service is healthy"
          }
        }
      }
    },
    "/api/v1/score/health": {
      "get": {
        "tags": [
          "Score"
        ],
        "summary": "Score service health",
        "description": "Allowed roles: public.",
        "x-allowed-roles": [
          "public"
        ],
        "responses": {
          "200": {
            "description": "Score service is healthy"
          }
        }
      }
    },
    "/api/v1/read/health": {
      "get": {
        "tags": [
          "Read"
        ],
        "summary": "Read service health",
        "description": "Allowed roles: public.",
        "x-allowed-roles": [
          "public"
        ],
        "responses": {
          "200": {
            "description": "Read service is healthy"
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register user",
        "description": "Allowed roles: public.",
        "x-allowed-roles": [
          "public"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthPayload"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered"
          },
          "400": {
            "description": "Validation error"
          },
          "409": {
            "description": "User already exists"
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login user",
        "description": "Allowed roles: public.",
        "x-allowed-roles": [
          "public"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Current user profile",
