<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <main class="page">
      <nav class="top-nav">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link active-link" href="/auth-demo">Auth</a>
        <a class="nav-link" href="/register-demo">Register</a>
        <a class="nav-link" href="/score-demo">Score</a>
        <a class="nav-link" href="/target-demo">Target</a>
        <a class="nav-link" href="/read-demo">Read</a>
        <a class="nav-link" href="/clock-demo">Clock</a>
        <a class="nav-link" href="/mail-demo">Mail</a>
        <a class="nav-link" href="/api-docs">API Docs</a>
      </nav>

      <section class="hero">
        <h1><%= title %></h1>
      </section>

      <section class="card">
        <div class="card-header">
          <h2>Gateway Health</h2>
          <button id="health-button" type="button">Check health</button>
        </div>
        <pre id="health-result">Nog niet getest.</pre>
      </section>

      <section class="grid">
        <section class="card">
          <h2>Register</h2>
          <form id="register-form">
            <label for="register-email">Email</label>
            <input id="register-email" name="email" type="email" placeholder="test@example.com" required />

            <label for="register-password">Wachtwoord</label>
            <input id="register-password" name="password" type="password" placeholder="123456" required />

            <label for="register-role">Rol</label>
            <select id="register-role" name="role">
              <option value="participant">participant</option>
              <option value="target-owner">target-owner</option>
            </select>

            <button type="submit">Register</button>
          </form>
          <pre id="register-result">Nog geen request verstuurd.</pre>
        </section>

        <section class="card">
          <h2>Login</h2>
          <form id="login-form">
            <label for="login-email">Email</label>
            <input id="login-email" name="email" type="email" placeholder="test@example.com" required />

            <label for="login-password">Wachtwoord</label>
            <input id="login-password" name="password" type="password" placeholder="123456" required />

            <button type="submit">Login</button>
          </form>
          <pre id="login-result">Nog geen request verstuurd.</pre>
        </section>
      </section>

      <section class="card">
        <div class="card-header">
          <h2>Stored Token</h2>
          <button id="clear-token-button" type="button">Clear token</button>
        </div>
        <pre id="token-result">Nog geen token opgeslagen.</pre>
      </section>
    </main>

    <script>
      function showJson(elementId, payload) {
        document.getElementById(elementId).textContent = JSON.stringify(payload, null, 2);
      }

      function updateStoredTokenView() {
        const token = localStorage.getItem('demo_jwt_token');
        if (!token) {
          document.getElementById('token-result').textContent = 'Nog geen token opgeslagen.';
          return;
        }

        showJson('token-result', { token });
      }

      async function requestJson(url, options) {
        const response = await fetch(url, options);
        const text = await response.text();

        try {
          return {
            status: response.status,
            ok: response.ok,
            body: JSON.parse(text)
          };
        } catch (error) {
          return {
            status: response.status,
            ok: response.ok,
            body: text
          };
        }
      }

      document.getElementById('health-button').addEventListener('click', async function() {
        try {
          const result = await requestJson('/api/v1/health', { method: 'GET' });
          showJson('health-result', result);
        } catch (error) {
          showJson('health-result', { error: error.message });
        }
      });

      document.getElementById('register-form').addEventListener('submit', async function(event) {
        event.preventDefault();

        const formData = new FormData(event.target);
        const payload = {
          email: formData.get('email'),
          password: formData.get('password'),
          role: formData.get('role')
        };

        try {
          const result = await requestJson('/api/v1/auth/register', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
          });

          if (result.ok && result.body.token) {
            localStorage.setItem('demo_jwt_token', result.body.token);
            updateStoredTokenView();
          }

          showJson('register-result', result);
        } catch (error) {
          showJson('register-result', { error: error.message });
        }
      });

      document.getElementById('login-form').addEventListener('submit', async function(event) {
        event.preventDefault();

        const formData = new FormData(event.target);
        const payload = {
          email: formData.get('email'),
          password: formData.get('password')
        };

        try {
          const result = await requestJson('/api/v1/auth/login', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
          });

          if (result.ok && result.body.token) {
            localStorage.setItem('demo_jwt_token', result.body.token);
            updateStoredTokenView();
          }

          showJson('login-result', result);
        } catch (error) {
          showJson('login-result', { error: error.message });
        }
      });

      document.getElementById('clear-token-button').addEventListener('click', function() {
        localStorage.removeItem('demo_jwt_token');
        updateStoredTokenView();
      });

      updateStoredTokenView();
    </script>
  </body>
</html>
