<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <main class="page">
      <nav class="top-nav">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/auth-demo">Auth</a>
        <a class="nav-link" href="/register-demo">Register</a>
        <a class="nav-link active-link" href="/score-demo">Score</a>
        <a class="nav-link" href="/target-demo">Target</a>
        <a class="nav-link" href="/read-demo">Read</a>
        <a class="nav-link" href="/clock-demo">Clock</a>
        <a class="nav-link" href="/mail-demo">Mail</a>
        <a class="nav-link" href="/api-docs">API Docs</a>
      </nav>

      <section class="hero">
        <h1><%= title %></h1>
      </section>

      <section class="card">
        <h2>Test Inputs</h2>
        <form id="score-form">
          <label for="score-target-id">Target ID</label>
          <input id="score-target-id" name="targetId" type="text" placeholder="Mongo ObjectId" required />

          <label for="score-image-url">Submission Image URL</label>
          <input id="score-image-url" name="imageUrl" type="url" placeholder="https://..." />

          <label for="score-submission-id">Submission ID</label>
          <input id="score-submission-id" name="submissionId" type="text" placeholder="Wordt automatisch gevuld na create" />

          <label for="score-token">JWT Token</label>
          <textarea id="score-token" name="token" rows="5" placeholder="Laat leeg om localStorage token te gebruiken"></textarea>
        </form>
        <p class="helper-text">Als het tokenveld leeg is, gebruikt deze pagina automatisch `demo_jwt_token` uit localStorage.</p>
      </section>

      <section class="grid">
        <section class="card">
          <h2>Health</h2>
          <button id="score-health-button" type="button">Check score health</button>
          <pre id="score-health-result">Nog niet getest.</pre>
        </section>

        <section class="card">
          <h2>Create Submission</h2>
          <button id="create-submission-button" type="button">Create submission</button>
          <pre id="create-submission-result">Nog geen request verstuurd.</pre>
        </section>

        <section class="card">
          <h2>My Score</h2>
          <button id="my-score-button" type="button">Load my score</button>
          <pre id="my-score-result">Nog geen request verstuurd.</pre>
        </section>

        <section class="card" data-role-required="target-owner">
          <h2>All Scores</h2>
          <button id="all-scores-button" type="button">Load all scores</button>
          <pre id="all-scores-result">Nog geen request verstuurd.</pre>
        </section>

        <section class="card">
          <h2>Winner</h2>
          <button id="winner-button" type="button">Load winner</button>
          <pre id="winner-result">Nog geen request verstuurd.</pre>
        </section>

        <section class="card" data-role-required="participant,target-owner">
          <h2>Delete Submission</h2>
          <p class="helper-text">Participants can delete their own submission. Target owners can delete submissions on their own target.</p>
          <button id="delete-submission-button" type="button">Delete submission</button>
          <pre id="delete-submission-result">Nog geen request verstuurd.</pre>
        </section>

        <section class="card">
          <h2>Current Token</h2>
          <button id="refresh-score-token-button" type="button">Refresh token view</button>
          <pre id="current-score-token-result">Nog geen token gevonden.</pre>
        </section>
      </section>
    </main>

    <script>
      function showJson(elementId, payload) {
        document.getElementById(elementId).textContent = JSON.stringify(payload, null, 2);
      }

      function getToken() {
        const manualToken = document.getElementById('score-token').value.trim();
        return manualToken || localStorage.getItem('demo_jwt_token') || '';
      }

      function parseJwtPayload(token) {
        try {
          var parts = String(token || '').split('.');

          if (parts.length < 2) {
            return null;
          }

          var normalized = parts[1].replace(/-/g, '+').replace(/_/g, '/');
          var padded = normalized + '='.repeat((4 - normalized.length % 4) % 4);
          return JSON.parse(atob(padded));
        } catch (error) {
          return null;
        }
      }

      function getCurrentRole() {
        var payload = parseJwtPayload(getToken());
        return payload && payload.role ? payload.role : null;
      }

      function applyRoleVisibility() {
        var role = getCurrentRole();
        var restricted = document.querySelectorAll('[data-role-required]');

        restricted.forEach(function(element) {
          var required = String(element.getAttribute('data-role-required') || '')
            .split(',')
            .map(function(value) { return value.trim(); })
            .filter(Boolean);

          var allowed = role && required.indexOf(role) !== -1;
          element.style.display = allowed ? '' : 'none';
        });
      }

      function getTargetId() {
        return document.getElementById('score-target-id').value.trim();
      }

      function getSubmissionId() {
        return document.getElementById('score-submission-id').value.trim();
      }

      function getImageUrl() {
        return document.getElementById('score-image-url').value.trim();
      }

      function updateTokenView() {
        const token = getToken();
        if (!token) {
          document.getElementById('current-score-token-result').textContent = 'Nog geen token gevonden.';
          applyRoleVisibility();
          return;
        }

        showJson('current-score-token-result', { token });
        applyRoleVisibility();
      }

      async function requestJson(url, options) {
        const response = await fetch(url, options);
        const text = await response.text();

        try {
          return {
            status: response.status,
            ok: response.ok,
            body: JSON.parse(text)
          };
        } catch (error) {
          return {
            status: response.status,
            ok: response.ok,
            body: text
          };
        }
      }

      function buildAuthHeaders() {
        const token = getToken();
        const headers = {
          'Content-Type': 'application/json'
        };

        if (token) {
          headers.Authorization = 'Bearer ' + token;
        }

        return headers;
      }

      document.getElementById('score-health-button').addEventListener('click', async function() {
        try {
          const result = await requestJson('/api/v1/score/health', { method: 'GET' });
          showJson('score-health-result', result);
        } catch (error) {
          showJson('score-health-result', { error: error.message });
        }
      });

      document.getElementById('create-submission-button').addEventListener('click', async function() {
        const targetId = getTargetId();
        const imageUrl = getImageUrl();

        if (!targetId || !imageUrl) {
          showJson('create-submission-result', { message: 'Target ID en image URL zijn verplicht.' });
          return;
        }

        try {
          const result = await requestJson('/api/v1/targets/' + encodeURIComponent(targetId) + '/submissions', {
            method: 'POST',
            headers: buildAuthHeaders(),
            body: JSON.stringify({ imageUrl: imageUrl })
          });

          showJson('create-submission-result', result);

          if (result.ok && result.body && result.body.submission && result.body.submission.submissionId) {
            document.getElementById('score-submission-id').value = result.body.submission.submissionId;
          }
        } catch (error) {
          showJson('create-submission-result', { error: error.message });
        }
      });

      document.getElementById('my-score-button').addEventListener('click', async function() {
        const targetId = getTargetId();

        if (!targetId) {
          showJson('my-score-result', { message: 'Vul eerst een Target ID in.' });
          return;
        }

        try {
          const result = await requestJson('/api/v1/targets/' + encodeURIComponent(targetId) + '/score', {
            method: 'GET',
            headers: buildAuthHeaders()
          });
          showJson('my-score-result', result);
        } catch (error) {
          showJson('my-score-result', { error: error.message });
        }
      });

      document.getElementById('all-scores-button').addEventListener('click', async function() {
        const targetId = getTargetId();

        if (!targetId) {
          showJson('all-scores-result', { message: 'Vul eerst een Target ID in.' });
          return;
        }

        try {
          const result = await requestJson('/api/v1/targets/' + encodeURIComponent(targetId) + '/scores', {
            method: 'GET',
            headers: buildAuthHeaders()
          });
          showJson('all-scores-result', result);
        } catch (error) {
          showJson('all-scores-result', { error: error.message });
        }
      });

      document.getElementById('winner-button').addEventListener('click', async function() {
        const targetId = getTargetId();

        if (!targetId) {
          showJson('winner-result', { message: 'Vul eerst een Target ID in.' });
          return;
        }

        try {
          const result = await requestJson('/api/v1/targets/' + encodeURIComponent(targetId) + '/winner', {
            method: 'GET',
            headers: buildAuthHeaders()
          });
          showJson('winner-result', result);
        } catch (error) {
          showJson('winner-result', { error: error.message });
        }
      });

      document.getElementById('delete-submission-button').addEventListener('click', async function() {
        const submissionId = getSubmissionId();

        if (!submissionId) {
          showJson('delete-submission-result', { message: 'Vul eerst een Submission ID in.' });
          return;
        }

        try {
          const result = await requestJson('/api/v1/submissions/' + encodeURIComponent(submissionId), {
            method: 'DELETE',
            headers: buildAuthHeaders()
          });
          showJson('delete-submission-result', result);
        } catch (error) {
          showJson('delete-submission-result', { error: error.message });
        }
      });

      document.getElementById('refresh-score-token-button').addEventListener('click', updateTokenView);
      document.getElementById('score-token').addEventListener('input', applyRoleVisibility);

      updateTokenView();
      applyRoleVisibility();
    </script>
  </body>
</html>
