NODE_ENV=production

GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
TARGET_SERVICE_PORT=3002
REGISTER_SERVICE_PORT=3003
CLOCK_SERVICE_PORT=3004
SCORE_SERVICE_PORT=3005
MAIL_SERVICE_PORT=3006
READ_SERVICE_PORT=3007

AUTH_SERVICE_URL=http://auth-service:3001
TARGET_SERVICE_URL=http://target-service:3002
REGISTER_SERVICE_URL=http://register-service:3003
SCORE_SERVICE_URL=http://score-service:3005
CLOCK_SERVICE_URL=http://clock-service:3004
MAIL_SERVICE_URL=http://mail-service:3006
READ_SERVICE_URL=http://read-service:3007

AUTH_MONGODB_URI=mongodb://mongodb:27017/photo-prestige
TARGET_MONGODB_URI=mongodb://mongodb:27017/photo-prestige
REGISTER_MONGODB_URI=mongodb://register-mongodb:27017/register-service
SCORE_MONGODB_URI=mongodb://score-mongodb:27017/score-service
CLOCK_MONGODB_URI=mongodb://clock-mongodb:27017/clock-service
MAIL_MONGODB_URI=mongodb://mail-mongodb:27017/mail-service

JWT_SECRET=change-this-in-real-deployments
JWT_EXPIRES_IN=1d

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=photo-prestige
RABBITMQ_RECONNECT_DELAY_MS=5000
GATEWAY_PROXY_TIMEOUT_MS=5000
GATEWAY_RETRY_ATTEMPTS=3
GATEWAY_RETRY_DELAY_MS=250
GATEWAY_CIRCUIT_BREAKER_THRESHOLD=3
GATEWAY_CIRCUIT_BREAKER_RESET_TIMEOUT_MS=10000
DEADLINE_REMINDER_MINUTES=60
DEADLINE_REMINDER_INTERVAL_MINUTES=60
CLOCK_POLL_INTERVAL_MS=5000

IMAGGA_API_KEY=
IMAGGA_API_SECRET=
IMAGGA_API_BASE_URL=https://api.imagga.com/v2
SENDGRID_API_KEY=
MAIL_FROM=Photo Prestige <noreply@example.com>
